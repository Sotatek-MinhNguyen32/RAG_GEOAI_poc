# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=12345678
S3_BUCKET=warehouse

# ── Elasticsearch / OpenSearch ──
ES_URL=http://localhost:9200
ES_INDEX=images_metadata
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_MODE=dev           # dev | prod
OPENSEARCH_REGION=us-east-1   # AWS region (prod only)

# ── Qdrant ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=desc_embed
QDRANT_COLLECTION_SIZE=2048   # must match EMBED_DIM

# ── Embedding (Jina v4) ──
EMBED_URL=http://localhost:8001
EMBED_DIM=2048

# ── VLM ──
VLM_URL=http://localhost:8002

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Dev flags ──
USE_MOCK=True
