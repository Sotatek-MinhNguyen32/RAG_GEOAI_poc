# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=12345678
S3_BUCKET=warehouse

# ── Elasticsearch ──
ES_URL=http://localhost:9200
ES_INDEX=images_metadata

# ── Qdrant ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=desc_embed

# ── Embedding (Jina v4) ──
EMBED_URL=http://localhost:8001
EMBED_DIM=2048

# ── VLM ──
VLM_URL=http://localhost:8002

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
